# Provided automatically by Railway PostgreSQL plugin
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/railway"

# JWT secrets — generate random strings (e.g. openssl rand -hex 32)
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=production

# CORS — comma-separated list of allowed client origins
CLIENT_ORIGIN="https://employeeqa.site,https://www.employeeqa.site"

# File uploads
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_BYTES=5242880
